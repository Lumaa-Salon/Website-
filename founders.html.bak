<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Our Founders — Lumaa Salon</title>
  <meta name="description" content="Meet the founders behind Lumaa Salon — Gagan & Mridul, the people shaping the salon." />
  <link rel="icon" type="image/webp" href="images/lumaa-logo-white.webp" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,500&family=Playfair+Display:ital,wght@0,600;1,700&family=Jost:wght@300;400;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --cream: #EED9BF;
      --sage:  #9CA175;
      --offwhite: #F6F2EB;
      --earth: #937B67;
      --deep:  #2E3326;
      --ink:   #2B2922;
      --white: #FFFFFF;
      --cream-rgb: 238, 217, 191;
      --sage-rgb:  156, 161, 117;
      --earth-rgb: 147, 123, 103;
      --ink-rgb:   43, 41, 34;
      --serif:   'Playfair Display', serif;
      --display: 'Cormorant Garamond', serif;
      --sans:    'Jost', sans-serif;
    }

    html { scroll-behavior: smooth; }
    body { font-family: var(--sans); background: var(--white); color: var(--ink); -webkit-font-smoothing: antialiased; }
    a { text-decoration: none; color: inherit; }
    img { display: block; max-width: 100%; }

    /* ── NAVBAR ── */
    .navbar {
      position: fixed; inset: 0 0 auto 0; z-index: 50;
      display: flex; align-items: center; justify-content: space-between;
      padding: 18px 40px;
      transition: background 0.35s ease, padding 0.35s ease, box-shadow 0.35s ease;
    }
    .navbar.scrolled {
      background: rgba(255, 255, 255, 0.96);
      backdrop-filter: blur(10px);
      padding: 12px 40px;
      box-shadow: 0 4px 20px rgba(var(--ink-rgb), 0.08);
    }
    .nav-cta {
      display: inline-flex; align-items: center; gap: 8px;
      background: var(--sage); color: var(--white);
      font-size: 0.75rem; letter-spacing: 0.14em; text-transform: uppercase;
      font-weight: 600; padding: 11px 22px; border-radius: 999px;
      transition: background 0.25s ease, transform 0.2s ease, box-shadow 0.25s ease;
    }
    .nav-cta:hover { background: var(--deep); transform: translateY(-1px); box-shadow: 0 6px 16px rgba(var(--sage-rgb), 0.35); }
    .nav-cta svg { width: 16px; height: 16px; }
    .brand { display: inline-flex; align-items: center; }
    .logo { height: 42px; width: auto; }
    .nav-links { display: flex; gap: 34px; }
    .nav-links a {
      color: var(--ink); font-size: 0.8rem; letter-spacing: 0.18em;
      text-transform: uppercase; font-weight: 400;
      position: relative; padding: 4px 0; transition: color 0.2s ease;
    }
    .nav-links a.active,
    .nav-links a:hover { color: var(--sage); }
    .nav-links a::after {
      content: ''; position: absolute; left: 0; bottom: -2px;
      width: 0; height: 1px; background: var(--sage); transition: width 0.3s ease;
    }
    .nav-links a:hover::after,
    .nav-links a.active::after { width: 100%; }
    .hamburger { display: none; flex-direction: column; gap: 5px; background: none; border: 0; cursor: pointer; padding: 6px; }
    .hamburger span { width: 24px; height: 2px; background: var(--ink); transition: transform 0.3s ease, opacity 0.3s ease; }
    .hamburger.active span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .hamburger.active span:nth-child(2) { opacity: 0; }
    .hamburger.active span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

    /* ── LEADERSHIP / FOUNDERS ── */
    .team { background: var(--white); padding: 92px 40px 96px; }
    .team-head { text-align: center; max-width: 640px; margin: 0 auto 72px; }
    .team-head .eyebrow {
      font-family: var(--sans); text-transform: uppercase;
      letter-spacing: 0.34em; font-size: 0.72rem; font-weight: 600;
      color: var(--sage); margin-bottom: 16px;
    }
    .team-head h1 {
      font-family: var(--serif); font-weight: 600;
      font-size: clamp(2.2rem, 4.6vw, 3.4rem);
      color: var(--ink); letter-spacing: -0.01em; line-height: 1.08;
    }
    .team-head p {
      margin-top: 14px; font-size: 1.05rem;
      color: rgba(var(--ink-rgb), 0.58); line-height: 1.6;
    }

    .team-rows { max-width: 1080px; margin: 0 auto; display: flex; flex-direction: column; gap: 84px; }
    .team-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 60px;
      align-items: center;
      opacity: 0; transform: translateY(38px);
      transition: opacity 0.8s cubic-bezier(0.22,1,0.36,1), transform 0.8s cubic-bezier(0.22,1,0.36,1);
    }
    .team-row.visible { opacity: 1; transform: none; }

    /* photo */
    .team-photo {
      border-radius: 16px;
      overflow: hidden;
      background: linear-gradient(160deg, var(--cream) 0%, rgba(var(--earth-rgb), 0.35) 100%);
      aspect-ratio: 4 / 3.4;
      display: flex; align-items: flex-end; justify-content: center;
      box-shadow: 0 18px 44px rgba(var(--ink-rgb), 0.12);
    }
    .team-photo img {
      width: 68%; height: 92%;
      object-fit: contain; object-position: bottom center;
    }

    /* info */
    .team-name {
      font-family: var(--serif); font-weight: 700;
      font-size: clamp(1.6rem, 2.8vw, 2.1rem);
      color: var(--ink); letter-spacing: -0.01em; line-height: 1.1;
    }
    .team-role {
      margin-top: 6px; font-size: 0.95rem; font-weight: 600;
      color: var(--sage); letter-spacing: 0.02em;
    }
    .team-bio {
      margin-top: 20px; font-size: 0.98rem; line-height: 1.78;
      color: rgba(var(--ink-rgb), 0.62); max-width: 460px;
    }
    .team-socials { display: flex; gap: 10px; margin-top: 24px; }
    .team-socials a {
      width: 36px; height: 36px; border-radius: 9px;
      display: inline-flex; align-items: center; justify-content: center;
      background: var(--ink); color: var(--white);
      transition: background 0.2s ease, transform 0.2s ease;
    }
    .team-socials a:hover { background: var(--sage); transform: translateY(-2px); }

    /* ── FOOTER ── */
    .founders-footer {
      background: var(--white);
      border-top: 1px solid rgba(var(--ink-rgb), 0.1);
      text-align: center; padding: 28px 40px;
      font-size: 0.82rem; color: rgba(var(--ink-rgb), 0.6);
      letter-spacing: 0.04em;
    }
    .founders-footer a { color: var(--ink); font-weight: 600; transition: color 0.2s; }
    .founders-footer a:hover { color: var(--sage); }

    /* ── RESPONSIVE ── */
    @media (max-width: 900px) {
      .navbar { padding: 16px 24px; }
      .navbar.scrolled { padding: 12px 24px; }
      .hamburger { display: flex; }
      .nav-links {
        position: absolute; top: 100%; left: 0; right: 0;
        flex-direction: column; gap: 0;
        background: rgba(255, 255, 255, 0.98);
        backdrop-filter: blur(10px);
        box-shadow: 0 8px 24px rgba(var(--ink-rgb), 0.1);
        max-height: 0; overflow: hidden;
        transition: max-height 0.35s ease;
      }
      .nav-links.open { max-height: 420px; }
      .nav-links a { padding: 15px 24px; border-top: 1px solid rgba(var(--ink-rgb), 0.07); }

      .team { padding: 86px 28px 72px; }
      .team-rows { gap: 40px; max-width: 560px; }
      /* keep the side-by-side alternating grid (image small, text wider) */
      .team-row { gap: 20px; align-items: center; }
      .team-row:nth-child(odd)  { grid-template-columns: 0.82fr 1.18fr; }
      .team-row:nth-child(even) { grid-template-columns: 1.18fr 0.82fr; }
      .team-photo { aspect-ratio: 3 / 4; }
      .team-bio { max-width: none; }
    }
    @media (max-width: 480px) {
      .nav-cta { font-size: 0.66rem; padding: 9px 16px; gap: 6px; }
      .nav-cta svg { width: 14px; height: 14px; }
      .navbar { padding: 14px 16px; }
      .team { padding: 74px 16px 56px; }
      .team-head { margin-bottom: 40px; }
      .team-rows { gap: 28px; }
      .team-row { gap: 12px; }
      .team-name { font-size: 1.12rem; }
      .team-role { font-size: 0.74rem; margin-top: 3px; }
      .team-bio { font-size: 0.74rem; line-height: 1.5; margin-top: 10px; }
      .team-socials { gap: 7px; margin-top: 12px; }
      .team-socials a { width: 28px; height: 28px; border-radius: 7px; }
      .team-socials svg { width: 14px; height: 14px; }
    }
  </style>
</head>
<body>

  <!-- ── NAVBAR ── -->
  <header class="navbar" id="navbar">
    <a href="index.html" class="brand">
      <img src="images/lumaa-logo-olive.webp" alt="Lumaa Salon" class="logo" />
    </a>
    <nav class="nav-links" id="navLinks">
      <a href="index.html#services">Services</a>
      <a href="index.html#gallery">Gallery</a>
      <a href="index.html#reviews">Reviews</a>
      <a href="index.html#contact">Contact</a>
      <a href="https://docs.google.com/forms/d/e/1FAIpQLScYBFybON-J7nFKHJC2IQqXxigCQ_ar4FxfF-Mzsk_BcsSYzg/viewform" target="_blank" rel="noopener">Franchise</a>
      <a href="founders.html" class="active">Founders</a>
    </nav>
    <button class="hamburger" id="hamburger" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </button>
  </header>

  <!-- ── LEADERSHIP / FOUNDERS ── -->
  <section class="team">
    <div class="team-head">
      <h1>Meet Our Founders</h1>
      <p>The people shaping Lumaa Salon.</p>
    </div>

    <div class="team-rows">

      <!-- Gagan — photo left, info right -->
      <div class="team-row">
        <div class="team-photo">
          <img src="a-simple-black-silhouette-of-man-in-suit-vector-55942263.avif" alt="Gagan" />
        </div>
        <div class="team-info">
          <h2 class="team-name">Gagan</h2>
          <p class="team-role">Co-Founder &amp; Creative Director</p>
          <p class="team-bio">Gagan leads Lumaa's artistry with over a decade of experience in hair and styling. His eye for detail and genuine love for the craft shape every look that leaves the salon.</p>
          <div class="team-socials">
            <a href="https://www.instagram.com/lumaasalon.official" target="_blank" rel="noopener" aria-label="Instagram">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            </a>
            <a href="https://wa.me/919205809126" target="_blank" rel="noopener" aria-label="WhatsApp">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.74.46 3.38 1.26 4.8L2.05 22l5.43-1.43a9.84 9.84 0 0 0 4.56 1.11c5.46 0 9.91-4.45 9.91-9.91S17.5 2 12.04 2zm4.88 13.42c-.2.56-1.16 1.08-1.6 1.14-.4.06-.93.09-1.5-.09-.35-.11-.8-.26-1.36-.52-2.39-1.02-3.96-3.41-4.08-3.57-.12-.15-.97-1.28-.97-2.44 0-1.16.61-1.73.83-1.97.22-.24.48-.3.63-.3h.45c.14 0 .34-.05.53.41.2.48.68 1.67.74 1.79.06.12.1.26.02.42-.08.16-.12.25-.24.39-.12.13-.25.3-.36.4-.12.11-.25.22-.1.44.14.22.6.97 1.27 1.57.87.77 1.6 1.01 1.83 1.12.23.11.36.09.49-.05.13-.14.56-.65.71-.88.15-.22.3-.18.5-.11.21.07 1.34.63 1.57.75.23.11.38.16.44.25.06.09.06.54-.14 1.09z"/></svg>
            </a>
            <a href="tel:+919205809126" aria-label="Call">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </a>
            <a href="mailto:mridul@lumaasalon.com" aria-label="Email">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Mridul — info left, photo right -->
      <div class="team-row">
        <div class="team-info">
          <h2 class="team-name">Mridul</h2>
          <p class="team-role">Co-Founder &amp; Managing Director</p>
          <p class="team-bio">Mridul turned a shared dream into a beloved brand. He looks after the client experience, day-to-day operations, and the warm, welcoming feeling that keeps Lumaa's guests coming back.</p>
          <div class="team-socials">
            <a href="https://www.instagram.com/lumaasalon.official" target="_blank" rel="noopener" aria-label="Instagram">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            </a>
            <a href="https://wa.me/919205809126" target="_blank" rel="noopener" aria-label="WhatsApp">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.74.46 3.38 1.26 4.8L2.05 22l5.43-1.43a9.84 9.84 0 0 0 4.56 1.11c5.46 0 9.91-4.45 9.91-9.91S17.5 2 12.04 2zm4.88 13.42c-.2.56-1.16 1.08-1.6 1.14-.4.06-.93.09-1.5-.09-.35-.11-.8-.26-1.36-.52-2.39-1.02-3.96-3.41-4.08-3.57-.12-.15-.97-1.28-.97-2.44 0-1.16.61-1.73.83-1.97.22-.24.48-.3.63-.3h.45c.14 0 .34-.05.53.41.2.48.68 1.67.74 1.79.06.12.1.26.02.42-.08.16-.12.25-.24.39-.12.13-.25.3-.36.4-.12.11-.25.22-.1.44.14.22.6.97 1.27 1.57.87.77 1.6 1.01 1.83 1.12.23.11.36.09.49-.05.13-.14.56-.65.71-.88.15-.22.3-.18.5-.11.21.07 1.34.63 1.57.75.23.11.38.16.44.25.06.09.06.54-.14 1.09z"/></svg>
            </a>
            <a href="tel:+919205809126" aria-label="Call">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </a>
            <a href="mailto:mridul@lumaasalon.com" aria-label="Email">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            </a>
          </div>
        </div>
        <div class="team-photo">
          <img src="a-simple-black-silhouette-of-man-in-suit-vector-55942263.avif" alt="Mridul" />
        </div>
      </div>

    </div>
  </section>

  <script>
    // Navbar solidify on scroll
    const navbar = document.getElementById('navbar');
    function onScroll() { navbar.classList.toggle('scrolled', window.scrollY > 40); }
    window.addEventListener('scroll', onScroll);
    onScroll();

    // Hamburger menu
    const hamburger = document.getElementById('hamburger');
    const navLinks  = document.getElementById('navLinks');
    hamburger.addEventListener('click', function () {
      navLinks.classList.toggle('open');
      this.classList.toggle('active');
    });
    navLinks.querySelectorAll('a').forEach(function (a) {
      a.addEventListener('click', function () {
        navLinks.classList.remove('open');
        hamburger.classList.remove('active');
      });
    });

    // Scroll-reveal for team rows
    const revealObserver = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          revealObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });
    document.querySelectorAll('.team-row').forEach(function (el) {
      revealObserver.observe(el);
    });
  </script>

</body>
</html>
